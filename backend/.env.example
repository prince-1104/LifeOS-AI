# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# ── Vector DB (Qdrant Cloud) ─────────────────────────────────────────
QDRANT_URL=
QDRANT_API_KEY=

# ── LLM API Keys ─────────────────────────────────────────────────────
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Clerk JWT verification ───────────────────────────────────────────
# JWKS URL from Clerk Dashboard → Configure → API keys
CLERK_JWKS_URL=https://YOUR_INSTANCE.clerk.accounts.dev/.well-known/jwks.json
# Issuer must match JWT "iss" (same host as above, no path)
CLERK_ISSUER=https://YOUR_INSTANCE.clerk.accounts.dev
# Optional: Clerk Backend API (server-side Clerk SDK)
CLERK_SECRET_KEY=

# ── Admin panel ──────────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# ── OneSignal push notifications ─────────────────────────────────────
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

# ── CORS (comma-separated origins) ──────────────────────────────────
# Set this to your Vercel frontend URL in production
CORS_ORIGINS=https://your-app.vercel.app

# ── Cashfree Payments (subscription billing) ─────────────────────────
# Get these from: Merchant Dashboard → Developers → API Keys
# Sandbox: https://merchant-sandbox.cashfree.com
# Production: https://merchant.cashfree.com
CASHFREE_CLIENT_ID=your_app_id
CASHFREE_CLIENT_SECRET=your_secret_key
CASHFREE_WEBHOOK_SECRET=your_webhook_secret
CASHFREE_ENV=sandbox  # "sandbox" or "production"

# ── Currency conversion ──────────────────────────────────────────────
INR_PER_USD=83.0


